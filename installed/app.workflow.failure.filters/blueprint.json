{
  "id": "bp.workflow.failure.filters",
  "name": "Workflow Failure Filters App",
  "goal": "filter workflow failures",
  "version": "0.1.0",
  "source_path": null,
  "app_shape": "generic",
  "roles": [
    {
      "id": "r1",
      "name": "agent",
      "type": "agent",
      "responsibilities": [],
      "permissions": [],
      "visible_views": [],
      "accessible_data": [],
      "allowed_actions": []
    }
  ],
  "tasks": [],
  "workflows": [
    {
      "id": "wf.failure.filtered",
      "name": "failure filtered",
      "triggers": [
        "manual"
      ],
      "steps": [
        {
          "id": "blocked.skill",
          "kind": "skill",
          "ref": "skill.blocked",
          "config": {
            "mode": "fail"
          }
        }
      ]
    },
    {
      "id": "wf.success.other",
      "name": "success other",
      "triggers": [
        "manual"
      ],
      "steps": [
        {
          "id": "set.ok",
          "kind": "module",
          "ref": "state.set",
          "config": {
            "key": "ok",
            "value": {
              "done": true
            }
          }
        }
      ]
    }
  ],
  "views": [],
  "required_modules": [
    "state.set"
  ],
  "required_skills": [],
  "storage_plan": {
    "user_data": "user",
    "app_data": "app",
    "runtime_state": "runtime",
    "system_metadata": "system"
  },
  "runtime_policy": {
    "execution_mode": "service",
    "activation": "on_demand",
    "restart_policy": "on_failure",
    "persistence_level": "full",
    "idle_strategy": "keep_alive",
    "max_restart_attempts": 3,
    "allow_prompt_invoke": true,
    "prompt_invoke_requires_ask_user": false
  },
  "runtime_profile": {
    "runtime_intelligence_level": "L0_deterministic",
    "runtime_network_requirement": "N0_none",
    "offline_capable": true,
    "direct_start_supported": true,
    "invocation_posture": "automatic",
    "runtime_skills": []
  }
}